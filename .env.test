# Test environment — committed intentionally with DUMMY values.
#
# `src/server/env.ts` parses every required env var at module load with zod,
# so any test file that transitively imports anything server-side would throw
# before the test body runs. This file keeps a syntactically-valid placeholder
# set so validation passes; the real DATABASE_URL is injected at runtime by
# `tests/setup/global-setup.ts` after Testcontainers spins up a Postgres
# instance.
#
# NEVER put real secrets here. For per-machine overrides use `.env.test.local`
# (gitignored via `.env*.local`).

NODE_ENV=test

# Placeholder — overridden at runtime by Testcontainers before any test
# actually uses the DB. Syntactically valid `z.string().url()` value.
DATABASE_URL=postgresql://test:test@127.0.0.1:5432/placeholder

AUTH_SECRET=test-secret-for-local-tests-never-use-in-prod
AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Nodemailer env vars — present so env.ts validates, Gmail is never hit
# in tests (Nodemailer transport is `vi.mock`-ed by email-flow tests).
GMAIL_USER=test@example.com
GMAIL_APP_PASSWORD=test-password-noop-in-tests

CRON_SECRET=test-cron-secret
