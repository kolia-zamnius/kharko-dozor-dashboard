// Generated client at `src/generated/prisma/`; migrations applied via
// `npx prisma migrate dev` against the Neon unpooled URL (see prisma.config.ts).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

/// Exactly one `PERSONAL` org per user — auto-created in the `createUser`
/// Auth.js event, can't be deleted, single member can't be removed. `TEAM`
/// supports full CRUD + multi-member invites.
enum OrgType {
  PERSONAL
  TEAM
}

/// Capability matrix lives in `src/server/auth/permissions.ts` (rank-based:
/// OWNER=2, ADMIN=1, VIEWER=0). Double-validated — UI hides + API 403s.
enum Role {
  /// Governance — invite lifecycle, role changes, API key lifecycle, destructive deletes.
  OWNER
  /// Day-to-day edits — no key-material access (plaintext or regen).
  ADMIN
  /// Read-only. Can self-leave orgs and edit own profile.
  VIEWER
}

/// PENDING is the only live state; ACCEPTED + EXPIRED are terminal. Expiry
/// is lazy (per-read via `expireStaleInvites`) plus a daily cleanup cron.
enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── Auth.js Models ──────────────────────────────────────

/// Auth.js fields (`email`, `emailVerified`, `image`) follow the adapter
/// contract; personal org auto-provisioned in `src/server/auth/events.ts`.
model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String    @unique
  emailVerified        DateTime?
  /// DiceBear `shapes` style, deterministic per user id. Override-able via avatar regen.
  image                String
  /// `SetNull` FK + the daily-cleanup cron's pre-delete null-sweep — the JWT
  /// callback falls back to personal space when this is null.
  activeOrganizationId String?
  /// Free-form String, not a Prisma enum, so adding a locale to `LOCALES`
  /// doesn't need a schema migration. `hasLocale` narrows unknown persisted
  /// values back to `DEFAULT_LOCALE` at read time.
  locale               String    @default("en")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  activeOrganization   Organization?         @relation("activeOrg", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  accounts             Account[]
  authenticators       Authenticator[]
  memberships          Membership[]
  createdOrganizations Organization[]
  invites              Invite[]
  inviteSendRateLimits InviteSendRateLimit[]
}

/// Managed by the Auth.js Prisma adapter. One user → many providers (Google + GitHub + passkey).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Auth.js Nodemailer OTP token — Auth.js v5 uses JWT sessions, so there's
/// no Session table. Rows expire via `expires`, swept on next sign-in by Auth.js itself.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

/// Per-day invite-send counter scoped to a user (vs `OtpRateLimit`'s email).
/// Caps a compromised OWNER session at `INVITE_DAILY_LIMIT` per UTC day.
model InviteSendRateLimit {
  id        String   @id @default(cuid())
  userId    String
  count     Int      @default(1)
  /// `@db.Date` — `(userId, date)` unique auto-rolls at UTC midnight without explicit cleanup.
  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

/// Per-day OTP-send counter (`(email, date)`). Guards `OTP_DAILY_LIMIT` and
/// the inter-send cooldown. Bumped atomically in `bumpOtpRateLimit`.
model OtpRateLimit {
  id        String   @id @default(cuid())
  email     String
  count     Int      @default(1)
  /// `@db.Date` — `(email, date)` unique bucket-resets at UTC midnight.
  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, date])
  @@index([email])
}

/// WebAuthn passkey. Composite PK `(userId, credentialID)` + `credentialID @unique`
/// — double-guard so a credential id can't collide across users.
model Authenticator {
  credentialID         String   @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  name                 String   @default("Passkey")
  createdAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@index([userId])
}

// ─── Business Models ─────────────────────────────────────

/// RBAC boundary. Every user has ≥1 org (personal space, not deletable).
model Organization {
  id          String   @id @default(cuid())
  name        String
  /// DiceBear `glass` — visually distinct from user (`shapes`) and tracked-user
  /// (`big-smile`) avatars so the three kinds can't be confused on screen.
  image       String
  type        OrgType
  /// Audit only — permissions read from `Membership`. Nullable so account
  /// deletion null-sweeps instead of FK-Restrict-blocking `DELETE /api/user`.
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy      User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  activeForUsers User[]       @relation("activeOrg")
  memberships    Membership[]
  invites        Invite[]
  projects       Project[]
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

/// Duplicate PENDING invites for `(email, organizationId)` are refreshed in
/// place (not 409'd) — the route reuses the row and resets expiresAt/role/invitedById.
model Invite {
  id             String       @id @default(cuid())
  email          String
  role           Role         @default(VIEWER)
  status         InviteStatus
  /// 3-day TTL — see `INVITE_EXPIRY_DAYS` (shared between route math, email copy, extend helper).
  expiresAt      DateTime
  organizationId String
  /// Nullable so account deletion sets this to null instead of FK-Restrict
  /// blocking `DELETE /api/user`. Inviter-less PENDING rows pruned by daily cron.
  invitedById    String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation(fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
}

/// Plaintext in DB but treated as a secret at every boundary (branded
/// `ApiKeyPlaintext`, `maskApiKey` for display, copy endpoint with
/// `Cache-Control: no-store`). Regenerate atomically invalidates the old
/// key — no grace window, on purpose.
model Project {
  id             String    @id @default(cuid())
  name           String
  /// `dp_<32hex>`. Never leaks to client tree — list returns `maskedKey`,
  /// the copy button hits `/api/projects/[id]/key`.
  key            String    @unique
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  /// Bumped fire-and-forget on every accepted ingest batch — failures swallowed
  /// so a slow project-meta write doesn't break ingestion.
  lastUsedAt     DateTime?

  /// Project-wide fallback when a TrackedUser has no per-row override
  /// (see `resolveDisplayName` 4-level chain).
  defaultDisplayNameTraitKey String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions     Session[]
  trackedUsers TrackedUser[]

  @@index([organizationId])
  @@index([key])
}

/// Created via SDK `identify()`. Per-project uniqueness — same `externalId`
/// in two projects = two rows. `traits` is unvalidated JSON.
model TrackedUser {
  id         String   @id @default(cuid())
  /// SDK-supplied — anything the customer uses internally (email, uuid, numeric id).
  externalId String
  projectId  String
  /// Free-form payload from `Dozor.identify(traits)`. Cast `as SessionTraits`
  /// at read sites — that's the grep handle for the JSON→typed boundary.
  traits     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  /// First two priorities of the 4-level display-name chain (full chain in
  /// `src/api-client/tracked-users/resolve-display-name.ts`):
  /// 1. `customName` — admin-typed override
  /// 2. `displayNameTraitKey` — read `traits[this]` for this user
  customName          String?
  displayNameTraitKey String?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([projectId, externalId])
  @@index([projectId])
  /// Matches `/users` default `ORDER BY updatedAt DESC` for cursor pagination.
  @@index([projectId, updatedAt(sort: Desc)])
}

/// `(projectId, externalId)` makes re-ingest batches upsert idempotently.
/// `startedAt` is SDK wall-clock; `createdAt` is server insert — they diverge
/// on clock skew or delayed batches, list UI sorts by `createdAt` to match
/// "recently seen".
model Session {
  id            String    @id @default(cuid())
  externalId    String
  projectId     String
  /// `SetNull` so the recording stays replayable after the user is cleaned up.
  trackedUserId String?
  url           String?
  userAgent     String?
  screenWidth   Int?
  screenHeight  Int?
  language      String?
  startedAt     DateTime
  /// Nullable while live; populated on session-end (visibility change, SPA
  /// boundary, idle timeout).
  endedAt       DateTime?
  /// Denormalised by the ingest pipeline — list-page reads skip per-row event scans.
  duration      Int       @default(0)
  eventCount    Int       @default(0)
  createdAt     DateTime  @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trackedUser TrackedUser? @relation(fields: [trackedUserId], references: [id], onDelete: SetNull)
  events      Event[]
  slices      Slice[]

  @@unique([projectId, externalId])
  @@index([projectId])
  @@index([trackedUserId])
  /// Matches `/replays` default `WHERE projectId AND ORDER BY createdAt DESC`.
  @@index([projectId, createdAt(sort: Desc)])
}

/// Sliced on page navigation or idle gap > 30s. Each slice carries its own
/// rrweb Full Snapshot so the viewer can jump in without replaying earlier slices.
model Slice {
  id             String    @id @default(cuid())
  sessionId      String
  /// 0-based, strictly monotonic per session — primary URL identifier in
  /// the slice-events API routes.
  index          Int
  /// `init` | `idle` (gap > 60s) | `navigation` (SPA route change). Drives the slice-picker icon.
  reason         String
  pathname       String
  url            String
  viewportWidth  Int?
  viewportHeight Int?
  startedAt      DateTime
  /// Null while this is the most recent slice being recorded.
  endedAt        DateTime?
  duration       Int       @default(0)
  eventCount     Int       @default(0)
  createdAt      DateTime  @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  events  Event[]

  @@unique([sessionId, index])
  @@index([sessionId])
}

/// `timestamp` is `BigInt` to tolerate microsecond precision if rrweb ever
/// emits it (current builds emit ms — cast down to Number for client Date math).
/// `sliceId` nullable for SDK builds pre-dating slice markers — those events
/// fall back to `sliceIndex = 0` via `ensureDefaultSlice`.
model Event {
  id         String   @id @default(cuid())
  sessionId  String
  sliceId    String?
  /// Denormalised copy of `slice.index` so event-batch queries filter/group
  /// by slice without a join. Kept in sync by the ingest pipeline.
  sliceIndex Int?
  type       Int
  timestamp  BigInt
  data       Json
  createdAt  DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  slice   Slice?  @relation(fields: [sliceId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([sliceId])
}
