# Required while two upstream peer constraints resolve:
#   1. next-auth@5-beta peer-depends on nodemailer@^7.0.7; we run
#      nodemailer@^8.0.5 (behaves identically for our SMTP use).
#   2. next-auth@5-beta peer-depends on @simplewebauthn/{browser,server}@^9.0.x;
#      current releases are @13, but bumping would break the passkey flow
#      under the current next-auth beta.
# Revisit when next-auth@5 ships stable.
legacy-peer-deps=true
