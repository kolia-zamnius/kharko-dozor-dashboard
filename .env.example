# Absolute base URL of the running app — consumed by `apiFetch` when a
# Server Component prefetches through the query client. Node.js `fetch`
# can't resolve relative URLs like `/api/foo`, so we prepend this.
# Optional — falls back to `VERCEL_URL` (auto on Vercel) then `http://localhost:3000`.
APP_URL="http://localhost:3000"

# Auth.js
AUTH_URL="http://localhost:3000"
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email delivery — Nodemailer over Gmail SMTP.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Vercel Cron shared secret. Optional in local dev, REQUIRED in production.
# The cron endpoints verify `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=""

# Database (Neon)
DATABASE_URL="postgresql://...@...-pooler.*.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://...@...*.aws.neon.tech/neondb?sslmode=require"

# Observability — both optional. Leaving them unset is a no-op:
# the app keeps logging to stdout via pino, no events leave the box.
#   SENTRY_DSN  — paste from sentry.io after creating a Next.js project.
#                 Sentry stays disabled until this is set; capture calls
#                 become no-ops automatically.
#   LOG_LEVEL   — pino level: fatal | error | warn | info | debug | trace | silent.
#                 Defaults: `debug` in dev, `info` in prod, `silent` in tests.
SENTRY_DSN=""
LOG_LEVEL=""
