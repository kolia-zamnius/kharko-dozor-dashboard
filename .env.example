# Optional — falls back to VERCEL_URL then http://localhost:3000.
APP_URL="http://localhost:3000"

# Only set to "true" on the public demo. Toggles the "don't put real production
# data here" banner. Self-hosters leave unset.
NEXT_PUBLIC_KHARKO_DEMO_MODE=""

# At least ONE of: Google OAuth, GitHub OAuth, Email OTP (GMAIL_*). Boot-time
# refine in src/server/env.ts asserts this. The FE renders only the methods
# whose env pair is set.
AUTH_URL="http://localhost:3000"
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Required for Email OTP sign-in and for sending org invites. Omit for OAuth-only.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Required in production — cron routes verify `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=""

# Neon. Pooled URL for the app, unpooled for migrations (see prisma.config.ts).
DATABASE_URL="postgresql://...@...-pooler.*.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://...@...*.aws.neon.tech/neondb?sslmode=require"

# Both optional — unset = no-op (pino still logs to stdout).
# LOG_LEVEL: fatal | error | warn | info | debug | trace | silent (defaults: debug dev, info prod, silent test).
SENTRY_DSN=""
LOG_LEVEL=""
